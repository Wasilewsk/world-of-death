void play_click() {
    menu_click.stop();
    menu_click.play();
}

void play_win() {
    sound s;
    s.load("sounds/auctionwon.ogg");
    s.volume = music_volume;
    s.play_wait();
}

void play_notify() {
    sound s;
    s.load("sounds/auction.ogg");
    s.volume = music_volume;
    s.play_wait();
}

void play_alarm() {
    sound s;
    s.load("sounds/alarm4.ogg");
    s.volume = music_volume;
    s.play_wait();
}
